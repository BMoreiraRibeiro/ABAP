OR ALL ENTRIES","text":"<pre><code>SELECT carrid, connid FROM sflight INTO TABLE @DATA(lt_s).\nSELECT * FROM spfli INTO TABLE @DATA(lt_p)\n  FOR ALL ENTRIES IN @lt_s\n  WHERE carrid = @lt_s-carrid.\n</code></pre>"},{"location":"relatorios/","title":"Relat\u00f3rios ABAP (ALV e cl\u00e1ssicos)","text":""},{"location":"relatorios/alv_classico/","title":"ALV Cl\u00e1ssico","text":"<pre><code>CALL FUNCTION 'REUSE_ALV_GRID_DISPLAY'\n  EXPORTING\n    i_structure_name = 'SFLIGHT'\n  TABLES\n    t_outtab = lt_sflight.\n</code></pre>"},{"location":"relatorios/alv_oo/","title":"ALV OO (CL_SALV_TABLE)","text":"<pre><code>SELECT * FROM sflight INTO TABLE @DATA(lt_data).\ncl_salv_table=&gt;factory( IMPORTING r_salv_table = DATA(o_alv) CHANGING t_table = lt_data ).\no_alv-&gt;display( ).\n</code></pre>"},{"location":"relatorios/ex01/","title":"Relatorios Exemplo 01","text":"<pre><code>DATA(lv) = sy-datum.\nWRITE: / 'Exemplo ABAP ativo:', lv.\n</code></pre>"},{"location":"relatorios/ex02/","title":"Relatorios Exemplo 02","text":"<pre><code>DATA(lv) = sy-datum.\nWRITE: / 'Exemplo ABAP ativo:', lv.\n</code></pre>"},{"location":"relatorios/ex03/","title":"Relatorios Exemplo 03","text":"<pre><code>DATA(lv) = sy-datum.\nWRITE: / 'Exemplo ABAP ativo:', lv.\n</code></pre>"},{"location":"relatorios/ex04/","title":"Relatorios Exemplo 04","text":"<pre><code>DATA(lv) = sy-datum.\nWRITE: / 'Exemplo ABAP ativo:', lv.\n</code></pre>"},{"location":"relatorios/ex05/","title":"Relatorios Exemplo 05","text":"<pre><code>DATA(lv) = sy-datum.\nWRITE: / 'Exemplo ABAP ativo:', lv.\n</code></pre>"},{"location":"relatorios/ex06/","title":"Relatorios Exemplo 06","text":"<pre><code>DATA(lv) = sy-datum.\nWRITE: / 'Exemplo ABAP ativo:', lv.\n</code></pre>"},{"location":"relatorios/ex07/","title":"Relatorios Exemplo 07","text":"<pre><code>DATA(lv) = sy-datum.\nWRITE: / 'Exemplo ABAP ativo:', lv.\n</code></pre>"},{"location":"relatorios/ex08/","title":"Relatorios Exemplo 08","text":"<pre><code>DATA(lv) = sy-dat